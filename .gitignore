# =========================
# CONFIGURACIÓN DE APP (ATENCIÓN AQUÍ)
# =========================

# Ignorar propiedades locales que uses para sobreescribir (si crearas alguno)
backend/src/main/resources/application-local.properties

# PERMITIMOS application.properties porque ahora está limpio (solo placeholders)
# Si lo ignoras, la app fallará en Render.
!backend/src/main/resources/application.properties

# Angular: Permitimos environment.ts porque el build lo necesita.
# Asegúrate de no poner claves SECRETAS (sk_) aquí, solo PÚBLICAS (pk_).
!frontend/src/environments/environment.ts
!frontend/src/environments/environment.development.ts
!frontend/src/environments/environment.production.ts

